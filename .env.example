# Configuración de la empresa principal (las demás se gestionan desde la UI)
NIT_EMPRESA=901331657
NOMBRE_EMPRESA=1INVEST SAS
# Sigla / nombre corto para la selección rápida de empresa (opcional)
SIGLA_EMPRESA=1INVEST

# Clave secreta Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=cambiar-en-produccion

# Servidor (solo para desarrollo local)
HOST=0.0.0.0
PORT=5000

# Rutas locales (solo cuando USE_SQLITE=true)
DATA_DIR=data/
INPUT_DIR=input/
OUTPUT_DIR=output/

# Carpeta de las bases de datos SQLite (la principal y la de cada empresa).
# En Azure App Service se usa automáticamente /home/data/db (almacenamiento
# PERSISTENTE que sobrevive reinicios y despliegues). En local: db/.
# Solo defínela manualmente si quieres forzar otra ruta.
# DB_DIR=db
# DB_PATH=db/contable.db
# BD de sistema (registro central de empresas; y a futuro usuarios/roles).
# Por defecto vive junto a las demás en DB_DIR. En Azure SQL se ignora (todo
# vive en la misma BD; la tabla `empresas` queda como una tabla compartida más).
# SYSTEM_DB_PATH=db/sistema.db
# Modo journal de SQLite (en Azure se fuerza DELETE porque WAL no funciona
# sobre el sistema de archivos de red /home). En local por defecto: WAL.
# DB_JOURNAL_MODE=WAL

# Base de datos: SQLite (local) o Azure SQL (cloud)
USE_SQLITE=true

# Azure SQL Database (solo cuando USE_SQLITE=false)
# DATABASE_URL=Driver={ODBC Driver 18 for SQL Server};Server=tcp:<server>.database.windows.net,1433;Database=<db>;Uid=<user>;Pwd=<pass>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# Azure Blob Storage (dejar vacío para usar sistema de archivos local)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=contable-auto

# SIIGO API (opcional)
# SIIGO_USERNAME=
# SIIGO_ACCESS_KEY=

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
