# Configuración de la empresa principal (las demás se gestionan desde la UI)
NIT_EMPRESA=901331657
NOMBRE_EMPRESA=1INVEST SAS
# Sigla / nombre corto para la selección rápida de empresa (opcional)
SIGLA_EMPRESA=1INVEST

# Clave secreta Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=cambiar-en-produccion

# Autenticación / RBAC (Fase 3/4)
#  - dev   : stub de desarrollo (autologin de un admin local; sin login real).
#  - entra : App Service Authentication con Microsoft Entra ID (producción).
AUTH_MODE=dev
# Admin local del stub dev (se autoprovisiona con rol de administrador global).
DEV_AUTH_EMAIL=admin@local
DEV_AUTH_NOMBRE=Administrador (dev)
# Email que recibe admin global al iniciar sesión (bootstrap del 1er admin en Entra).
# Déjalo vacío salvo en el primer arranque con AUTH_MODE=entra.
BOOTSTRAP_ADMIN_EMAIL=
# Tenant de Entra permitido (GUID del directorio). Si se define, solo entran
# identidades de ese tenant (claim `tid`). Recomendado en producción.
# ENTRA_TENANT_ID=
# Endpoints de App Service Authentication (no suele hacer falta cambiarlos).
# ENTRA_LOGIN_PATH=/.auth/login/aad
# ENTRA_LOGOUT_PATH=/.auth/logout

# Servidor (solo para desarrollo local)
HOST=0.0.0.0
PORT=5000

# Rutas locales (solo cuando USE_SQLITE=true)
DATA_DIR=data/
INPUT_DIR=input/
OUTPUT_DIR=output/

# Carpeta de las bases de datos SQLite (la principal y la de cada empresa).
# En Azure App Service se usa automáticamente /home/data/db (almacenamiento
# PERSISTENTE que sobrevive reinicios y despliegues). En local: db/.
# Solo defínela manualmente si quieres forzar otra ruta.
# DB_DIR=db
# DB_PATH=db/contable.db
# BD de sistema (registro central de empresas; y a futuro usuarios/roles).
# Por defecto vive junto a las demás en DB_DIR. En Azure SQL se ignora (todo
# vive en la misma BD; la tabla `empresas` queda como una tabla compartida más).
# SYSTEM_DB_PATH=db/sistema.db
# Modo journal de SQLite (en Azure se fuerza DELETE porque WAL no funciona
# sobre el sistema de archivos de red /home). En local por defecto: WAL.
# DB_JOURNAL_MODE=WAL

# Base de datos: SQLite (local) o Azure SQL (cloud)
USE_SQLITE=true

# Azure SQL Database (solo cuando USE_SQLITE=false)
# DATABASE_URL=Driver={ODBC Driver 18 for SQL Server};Server=tcp:<server>.database.windows.net,1433;Database=<db>;Uid=<user>;Pwd=<pass>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# Azure Blob Storage (dejar vacío para usar sistema de archivos local)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=1contabot

# SIIGO API (opcional)
# SIIGO_USERNAME=
# SIIGO_ACCESS_KEY=

# ---------------------------------------------------------------------------
# RADIAN automático — importación diaria desde la DIAN (catalogo-vpfe.dian.gov.co)
# ---------------------------------------------------------------------------
# Las credenciales del portal y del correo se configuran por EMPRESA desde la UI
# (Flujos indirectos › RADIAN automático). Aquí solo van los valores globales y
# los secretos que se prefiera mantener fuera de la base de datos.

# Programador interno: si es true, la app web ejecuta la importación una vez al
# día a la hora configurada de cada empresa. Con varias instancias, déjalo en
# false y usa un cron externo (ver RADIAN_CRON_TOKEN) para no duplicarla.
# RADIAN_SCHEDULER_ENABLED=false
# Hora por defecto (HH:MM, 24h) si la empresa no define una.
# RADIAN_HORA_DEFAULT=06:00

# Token compartido que protege el endpoint POST /radian/auto/cron usado por un
# programador externo (Azure Scheduler, cron, GitHub Action). Vacío = endpoint
# deshabilitado. Llámalo con la cabecera X-Radian-Token o el parámetro ?token=.
# RADIAN_CRON_TOKEN=

# Correo del token (IMAP). Por empresa se configura en la UI; estas variables
# sirven como valor por defecto / para no guardar la contraseña en la BD.
# La contraseña de Gmail debe ser una CONTRASEÑA DE APLICACIÓN.
# DIAN_IMAP_HOST=imap.gmail.com
# DIAN_IMAP_PORT=993
# DIAN_EMAIL_USER=
# DIAN_EMAIL_PASSWORD=

# Datos del correo que envía la DIAN (normalmente no hace falta cambiarlos).
# DIAN_PORTAL_URL=https://catalogo-vpfe.dian.gov.co
# DIAN_EMAIL_REMITENTE=facturacionelectronica@dian.gov.co
# DIAN_EMAIL_ASUNTO=Token Acceso DIAN
# DIAN_EMAIL_ESPERA_SEG=300
# DIAN_EMAIL_INTERVALO_SEG=15

# Telemetría de Application Insights (Fase 4 — observabilidad). La fija
# azure-setup.sh §9 en el App Service; vacío = telemetría desactivada.
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
